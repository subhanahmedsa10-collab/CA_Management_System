# Backend Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_API_PORT=3001

# Database
DATABASE_PATH=./public/database/ca_system.db

# JWT Secret (Change in production!)
JWT_SECRET=your-secret-key-change-in-production

# Server
NODE_ENV=development
SERVER_PORT=3001

# Application
APP_NAME=CA Management System
APP_VERSION=1.0.0

# GST Configuration
DEFAULT_GST_PERCENTAGE=18

# Session
SESSION_TIMEOUT=24h

# Logging
LOG_LEVEL=info

# Features
ENABLE_DARK_MODE=true
ENABLE_EMAIL_REMINDERS=false
ENABLE_WHATSAPP_INTEGRATION=false
